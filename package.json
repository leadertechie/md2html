{
  "name": "@leadertechie/md2html",
  "version": "0.0.0",
  "description": "Markdown to HTML pipeline - parse markdown to AST, render to HTML or Lit templates",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "marked": "^15.0.0"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "markdown",
    "html",
    "ast",
    "parser",
    "renderer",
    "ssr"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {

    "type": "git",
    "url": "git+https://github.com/leadertechie/md2html.git"
  }
}
